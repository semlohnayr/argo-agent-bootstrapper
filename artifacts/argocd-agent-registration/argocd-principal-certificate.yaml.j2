---
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: argocd-principal-{{ ocp_cluster_name }}
  namespace: argocd
spec:
  secretName: argocd-principal-{{ ocp_cluster_name }}
  issuerRef:
    name: argocd-agent-ca
    kind: Issuer
  commonName: argocd-agent-{{ ocp_cluster_name }}
  subject:
    organizationalUnits:
      - {{ ocp_base_domain }}
  dnsNames:
  - argocd-agent-{{ ocp_cluster_name }}.{{ ocp_base_domain }}
